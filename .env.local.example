# CineWave Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================
# MongoDB Atlas (Free M0 Tier — 512MB)
# Sign up: https://www.mongodb.com/cloud/atlas
# Create free M0 cluster → Get connection string
# ============================================
MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/cinewave

# ============================================
# NextAuth.js
# Generate secret: openssl rand -base64 32
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ============================================
# Google OAuth (Free)
# Setup: https://console.cloud.google.com
# 1. Create project → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID
# 3. Add http://localhost:3000/api/auth/callback/google as redirect URI
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# Cloudinary (Free Tier — 25GB storage, 25GB bandwidth/month)
# Sign up: https://cloudinary.com
# Dashboard → Account Details for credentials
# Settings → Upload → Add unsigned upload preset named "cinewave_unsigned"
# ============================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=cinewave_unsigned

# ============================================
# TMDB API (Free — for database seeding)
# Sign up: https://www.themoviedb.org/signup
# Get API key: https://www.themoviedb.org/settings/api
# ============================================
TMDB_API_KEY=your_tmdb_api_key_here

# ============================================
# SSLCommerz Sandbox (Free for development)
# Register: https://developer.sslcommerz.com/registration/
# Get sandbox store ID and password after registration
# ============================================
SSLCOMMERZ_STORE_ID=your-sandbox-store-id
SSLCOMMERZ_STORE_PASSWORD=your-sandbox-store-password
SSLCOMMERZ_IS_LIVE=false

# ============================================
# Gmail SMTP (Free)
# 1. Enable 2-Step Verification on your Google Account
# 2. Generate App Password: Google Account → Security → App Passwords
# 3. Use the generated 16-char password below
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your.gmail@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=CineWave <your.gmail@gmail.com>

# ============================================
# App URL
# Change to your Vercel URL in production
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
